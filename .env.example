# ── Engram Configuration ──────────────────────────────────────────

# Core
BRAIN_DIR=~/.engram

# LLM endpoint (OpenAI-compatible)
ENGRAM_LLM_ENDPOINT=http://localhost:3456/v1/chat/completions

# Models
ENGRAM_EXTRACT_MODEL=claude-haiku-4-5
ENGRAM_RUMINATE_MODEL=claude-sonnet-4-6
ENGRAM_TOPICAL_MODEL=claude-sonnet-4-6
ENGRAM_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Source directories (set these to your actual paths)
ENGRAM_MEMORY_DIR=~/notes
ENGRAM_SESSIONS_DIR=~/.openclaw/agents/main/sessions
ENGRAM_CHATS_DIR=~/chats
ENGRAM_WORK_DIR=~/work-notes
ENGRAM_TOPICAL_DIR=~/research

# User identity (used in chat extraction for attribution)
ENGRAM_USER_NAME=User

# Extraction settings
ENGRAM_BATCH_SIZE=10
ENGRAM_TOPICAL_DOMAIN=topical
